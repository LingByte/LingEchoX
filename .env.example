# Machine Configuration
MACHINE_ID=

# Server Configuration
SERVER_NAME=
SERVER_DESC=
SERVER_URL=
SERVER_LOGO=
SERVER_TERMS_URL=
ADDR=:7070
MODE=development
API_SECRET_KEY=
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# Database Configuration
DB_DRIVER=sqlite
DSN=./ling.db

# Logging Configuration
LOG_LEVEL=info
LOG_FILENAME=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=5
LOG_DAILY=true

# Hybrid multi-SFU control plane (optional). RTCSFU_NODES is a JSON array, e.g.
# [{"id":"local-1","region":"dev","signal_url":"ws://127.0.0.1:7075/api/rtcsfu/v1/signal/ws","healthy":true}]
# signal_url should point at this server's WebSocket path (see static/rtcsfu_demo.html).
RTCSFU_ENABLED=false
# primary = 固定主控（可接收副节点注册）；replica = 仅连主控；standalone = 单机（默认，也可注册副节点到本机控制面）
RTCSFU_CLUSTER_ROLE=standalone
# replica：向主控注册/心跳（与主控 RTCSFU_API_KEY 一致）；SIGTERM/SIGINT 时 best-effort DELETE 注销。
RTCSFU_PRIMARY_BASE_URL=
# 与 RTCSFU_NODES 元素同形的 JSON 对象或数组（本副本的 id / signal_url 等）
RTCSFU_REPLICA_SELF_JSON=
RTCSFU_REPLICA_HEARTBEAT_SEC=30
# register = 每次心跳 POST 全量 JSON；touch = 首次 POST register 后仅 POST .../replica/touch 刷新 last_seen
RTCSFU_REPLICA_HEARTBEAT_MODE=register
# mTLS（replica→primary HTTP 客户端）：验证主控证书 / 出示客户端证书
RTCSFU_REPLICA_MTLS_CA_FILE=
RTCSFU_REPLICA_MTLS_CERT_FILE=
RTCSFU_REPLICA_MTLS_KEY_FILE=
# 仅开发环境：跳过主控服务端证书校验（勿在生产开启）
RTCSFU_REPLICA_MTLS_INSECURE_SKIP_VERIFY=false
# 主控：超过该秒数未 register/touch 的副本在路由中视为 unhealthy（0=关闭）
RTCSFU_REPLICA_STALE_SECONDS=0
# 主控：若设置，则 POST .../replica/touch 须带有效 HMAC（与副本同名的 RTCSFU_REPLICA_TOUCH_HMAC_SECRET）
RTCSFU_REPLICA_TOUCH_HMAC_SECRET=
# 副本：mint touch_token 的 TTL 秒数（0=默认 120）
RTCSFU_REPLICA_TOUCH_TOKEN_TTL_SECONDS=0
RTCSFU_NODES=
# If set, POST /api/rtcsfu/v1/join and WS signal accept either X-RTCSFU-Key (or ?api_key=) or a valid join_token.
RTCSFU_API_KEY=
# HMAC secret for room-bound join tokens. With RTCSFU_API_KEY set, POST /api/rtcsfu/v1/token mints tokens.
RTCSFU_JOIN_TOKEN_SECRET=
RTCSFU_JOIN_TOKEN_DEFAULT_TTL_SECONDS=3600
# 0 = cap at 86400 in handler
RTCSFU_JOIN_TOKEN_MAX_TTL_SECONDS=0
# ICE for clients + embedded Pion SFU (JSON array, browser shape). Empty = default STUN only.
# RTCSFU_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"u","credential":"p"}]
RTCSFU_ICE_SERVERS_JSON=
RTCSFU_MAX_ROOMS=5000
RTCSFU_MAX_PEERS_PER_ROOM=50
RTCSFU_WS_READ_TIMEOUT_SEC=70
RTCSFU_WS_PING_INTERVAL_SEC=25
RTCSFU_WS_MAX_MESSAGE_BYTES=786432
# Comma-separated allowed Origin prefixes for WebSocket; empty + MODE=production => same Host only.
RTCSFU_SIGNAL_ALLOWED_ORIGINS=
# If true, require RTCSFU_API_KEY or RTCSFU_JOIN_TOKEN_SECRET so signal is not anonymously open.
RTCSFU_SIGNAL_REQUIRE_AUTH=false
