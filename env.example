# SoulNexus 环境变量配置示例
# 复制此文件为 .env 并修改相应的配置值

# 基础配置
MODE=dev
ADDR=:7072

# 服务器信息配置（可选）
MACHINE_ID=1
SERVER_NAME=SoulNexus
SERVER_DESC=AI Voice Assistant Platform
SERVER_URL=http://localhost:7072
SERVER_LOGO=
SERVER_TERMS_URL=

# ===================
# 数据库配置
# ===================
# SQLite 配置（默认）
DB_DRIVER=sqlite
DSN=./ling.db

# PostgreSQL 配置（生产环境推荐）
# DB_DRIVER=postgres
# DSN=postgres://lingecho:your-password@localhost:5432/lingecho?sslmode=disable

# MySQL 配置
# DB_DRIVER=mysql
# DSN=lingecho:your-password@tcp(localhost:3306)/lingecho?charset=utf8mb4&collation=utf8mb4_unicode_ci&parseTime=True&loc=Local

# Neo4j 图数据库配置（可选）
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ===================
# API 配置
# ===================
API_PREFIX=/api
ADMIN_PREFIX=/admin
AUTH_PREFIX=/auth
DOCS_PREFIX=/api/docs

# ===================
# 平台全局管理员（与租户用户使用同一 POST {API_PREFIX}/login；JWT Issuer：lingvoice.platform）
# 默认管理员由 cmd/bootstrap.SeedService.seedPlatformAdmin() 在 platform_admins 表为空时种入：
#   email    : admin@lingecho.com
#   password : admin123
# 首次登录后请立即在「访问管理 / 平台管理员」处修改密码。
# ===================

# ===================
# 会话配置
# ===================
# SESSION_SECRET 留空时启动会使用进程级临时密钥（每次重启踢人，仅 dev 可用）。
# 生产必须设置一个足够长（32+ 字节）的随机字符串。
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_EXPIRE_DAYS=7

# ===================
# 跨域 (CORS)
# ===================
# 逗号分隔的允许跨域来源（必须精确匹配 Origin 头）。
# 留空 → 反射任意 Origin + 启用凭据（启动会 WARN，仅 dev 可用）。
# 生产强烈建议显式列出，例如：
#   CORS_ALLOWED_ORIGINS=https://console.example.com,https://api.example.com
CORS_ALLOWED_ORIGINS=

# ===================
# 录音访问 ACL
# ===================
# /uploads/sip/recordings/* 默认需要 Bearer JWT。
# UPLOADS_RECORDINGS_PUBLIC=true 让这些 URL 公开（启动会 WARN）。仅用于 dev/本地。
# 生产环境（GIN_MODE=release 或 APP_ENV=production）若设为 true 将拒绝启动。
UPLOADS_RECORDINGS_PUBLIC=

# ===================
# 租户自助注册 / AKSK
# ===================
# TENANT_SELF_REGISTER=true 才开放 POST /api/register（默认关闭）。
TENANT_SELF_REGISTER=
# CREDENTIAL_ALLOW_EMPTY_ALLOW_IP=true 允许 AK/SK 不填 IP 白名单（仅 dev）。
CREDENTIAL_ALLOW_EMPTY_ALLOW_IP=

# ===================
# WebSeat / VoiceDialog WS 鉴权
# ===================
# 浏览器坐席与 voicedialog WebSocket 的共享密钥；留空启动会 ERROR 拒绝所有 WS。
# 如需 dev 旁路鉴权，置 SIP_WEBSEAT_ALLOW_EMPTY_TOKEN=true / VOICE_DIALOG_ALLOW_EMPTY_TOKEN=true。
# 生产环境若启用上述 ALLOW_EMPTY_* 将拒绝启动。
SIP_WEBSEAT_WS_TOKEN=
VOICE_DIALOG_WS_TOKEN=

# ===================
# 性能观测 / 自动 pprof / Pyroscope
# ===================
# StartSystemMonitor 默认开启（CPU/Mem/Disk 每 5s 采样，供 /system/status 与
# listeners 读取）；下面两个仅控制可选的 profile 链路。
#
# PROFILE_AUTO_PPROF=true 时，CPU 使用率超过 PerformanceMonitorConfig.CPUThreshold
# (默认 90%) 会自动 dump 10s CPU pprof 到 ./pprof/cpu-<ts>.pprof。
# 注意：触发后 30s 才会重新评估，磁盘自行轮换。
PROFILE_AUTO_PPROF=

# Pyroscope 持续 profile 服务地址；留空则跳过（不影响主流程）。
# PYROSCOPE_APP_NAME 默认 ling-voice；PYROSCOPE_BASIC_AUTH_USER / _PASSWORD 可选。
# PYROSCOPE_MUTEX_RATE / _BLOCK_RATE 控制 runtime 的 mutex/block profiler 采样率（默认 5）。
PYROSCOPE_URL=
PYROSCOPE_APP_NAME=
PYROSCOPE_BASIC_AUTH_USER=
PYROSCOPE_BASIC_AUTH_PASSWORD=
PYROSCOPE_MUTEX_RATE=
PYROSCOPE_BLOCK_RATE=

# ===================
# LLM 配置
# ===================
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=deepseek-v3.1

# OpenAI 配置（用于WebRTC等场景）
OPENAI_TOKEN=your-openai-token
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=your-openai-api-key

# ===================
# 七牛云 ASR 配置
# ===================
QINIU_ASR_API_KEY=your-qiniu-asr-api-key
QINIU_ASR_BASE_URL=https://openai.qiniu.com/v1
QINIU_ASR_TIMEOUT=30
QINIU_ASR_SAMPLE_RATE=16000
QINIU_ASR_CHANNELS=1
QINIU_ASR_BITS=16
QINIU_ASR_ENABLE_PUNC=true

# ===================
# 七牛云 TTS 配置
# ===================
QINIU_TTS_API_KEY=your-qiniu-tts-api-key
QINIU_TTS_BASE_URL=https://openai.qiniu.com/v1
QINIU_TTS_TIMEOUT=30
QINIU_TTS_RETRIES=3

# ===================
# 腾讯云配置（语音服务）
# ===================
QCLOUD_APP_ID=your-qcloud-app-id
QCLOUD_SECRET_ID=your-qcloud-secret-id
QCLOUD_SECRET=your-qcloud-secret

# ===================
# 讯飞配置（语音服务）
# ===================
XUNFEI_APP_ID=your-xunfei-app-id
XUNFEI_API_KEY=your-xunfei-api-key
XUNFEI_BASE_URL=http://opentrain.xfyousheng.com
XUNFEI_WS_APP_ID=your-xunfei-ws-app-id
XUNFEI_WS_API_KEY=your-xunfei-ws-api-key
XUNFEI_WS_API_SECRET=your-xunfei-ws-api-secret
XUNFEI_TIMEOUT=30

# ===================
# 其他TTS提供商配置（可选）
# ===================
# Azure TTS
# AZURE_SUBSCRIPTION_KEY=your-azure-subscription-key
# AZURE_REGION=your-azure-region

# ElevenLabs TTS
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# FishSpeech TTS
# FISHSPEECH_API_KEY=your-fishspeech-api-key

# ===================
# 日志配置
# ===================
LOG_LEVEL=info
LOG_FILENAME=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=5
LOG_DAILY=true

# ===================
# 知识库配置
# ===================
# 是否启用知识库功能
KNOWLEDGE_BASE_ENABLED=false
# 知识库提供者：aliyun, milvus, qdrant, elasticsearch, pinecone
KNOWLEDGE_BASE_PROVIDER=aliyun

# 阿里云百炼知识库配置
BAILIAN_ACCESS_KEY_ID=your-bailian-access-key-id
BAILIAN_ACCESS_KEY_SECRET=your-bailian-access-key-secret
BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com
BAILIAN_WORKSPACE_ID=your-workspace-id
BAILIAN_CATEGORY_ID=your-category-id
BAILIAN_SOURCE_TYPE=DATA_CENTER_FILE
BAILIAN_PARSER=DASHSCOPE_DOCMIND
BAILIAN_STRUCT_TYPE=unstructured
BAILIAN_SINK_TYPE=BUILT_IN

# Milvus 知识库配置
MILVUS_ADDRESS=localhost:19530
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_COLLECTION=your-collection-name
MILVUS_DIMENSION=768

# Qdrant 知识库配置
QDRANT_BASE_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=your-collection-name
QDRANT_DIMENSION=384

# Elasticsearch 知识库配置
ELASTICSEARCH_BASE_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=your-index-name

# Pinecone 知识库配置
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_BASE_URL=https://api.pinecone.io
PINECONE_INDEX_NAME=your-index-name
PINECONE_DIMENSION=1536

# ===================
# 邮件配置
# ===================
# 邮件提供商: smtp 或 sendcloud (默认: sendcloud)
MAIL_PROVIDER=sendcloud

# SMTP 配置（当 MAIL_PROVIDER=smtp 时使用）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SendCloud 配置（当 MAIL_PROVIDER=sendcloud 时使用）
SENDCLOUD_API_USER=LingEcho
SENDCLOUD_API_KEY=your-sendcloud-api-key
SENDCLOUD_FROM_EMAIL=noreply@lingecho.com

# 通用邮件配置
MAIL_FROM_EMAIL=noreply@lingecho.com

# ===================
# 搜索配置
# ===================
SEARCH_ENABLED=true
SEARCH_PATH=./search
SEARCH_BATCH_SIZE=100
SEARCH_DELAY_INDEX=false

# ===================
# 备份配置
# ===================
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *

# ===================
# 监控配置
# ===================
MONITOR_PREFIX=/metrics
LANGUAGE_ENABLED=true
API_SECRET_KEY=your-api-secret-key-change-this-in-production
SIP_USER_ONLINE_SWEEP_SECONDS=30
# SDP c= / 外呼 SDP 本端 IP：使用 cmd/server -sip-local-ip（默认 127.0.0.1）；生产填公网或可路由 IP，否则对端 RTP 可能打丢
# SIP 下行 RTP 发送队列深度（PCM 帧数，越大越不易在长 TTS 时丢包卡顿；默认 512，范围 64–2048）
# SIP_MEDIA_TX_QUEUE_SIZE=512

# SIP RTP 端口策略（入呼/外呼共用）
# 固定单端口（可选，留空则不启用）
# SIP_RTP_PORT=40000
# 固定端口范围（生产环境推荐）
SIP_RTP_PORT_START=39900
SIP_RTP_PORT_END=40000

# 入呼：中继 DID 无法匹配到租户时是否仍接通。默认拒绝（404）；设为 1/true 则 tenant_id=0 放行（演示/单租户遗留）。
# SIP_INBOUND_ALLOW_UNKNOWN_DID=0

# 外呼 campaign 脚本 listen：播报结束后额外等待（ms，按文案长度估算，默认上限 2000）
# 设为 0 / false / off / no 可关闭该尾巴，仅用脚本里的 listen_timeout_ms
# SIP_SCRIPT_LISTEN_AFTER_TTS_TAIL=0
# SIP_SCRIPT_LISTEN_TAIL_MS_MAX=2000
# SIP_SCRIPT_LISTEN_TAIL_MS_MIN=400
# 等待下一句用户话轮时轮询 DB 的间隔 ms（默认 120，范围 50–500）；写入 sip_calls.turns 后会立即唤醒，不必单靠轮询
# SIP_SCRIPT_LISTEN_POLL_MS=120
# 脚本模式仅在 ASR final 写入用户话轮

# 外呼 hybrid 脚本 listen 分支：OpenAI 兼容 API 做语义选路（百炼/ DashScope 兼容模式、OpenAI 等）
# 配齐以下变量且某 listen 步骤的 transitions 合并 default 后存在 2 个及以上不同 next_id 时，必须由 LLM 选路；失败或未配置时播报 SIP_SCRIPT_LLM_FAIL_PROMPT 并结束脚本（不再使用 contains 关键字匹配）
# CHECK_LLM_PROVIDER=openai
# CHECK_LLM_BASEURL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CHECK_LLM_APIKEY=your-key
# CHECK_LLM_MODEL=qwen-plus
# CHECK_LLM_ROUTE_TIMEOUT_MS=12000
# CHECK_LLM_ROUTE_DISABLED=false
# 默认紧凑路由：模型只输出 {"i":N}（分支序号），更快更省 token；若要旧版 {"next_id":"..."} 设：
CHECK_LLM_ROUTE_LEGACY_JSON=1
CHECK_LLM_ROUTE_MAX_TOKENS=32
# listen 含 transitions 时若禁用 LLM 或路由失败，将播报以下文案并结束脚本（默认道歉挂机）
SIP_SCRIPT_LLM_FAIL_PROMPT=对不起，打扰了。

# 指标监控配置
METRICS_MAX_SPANS=1000
METRICS_MAX_QUERIES=100
METRICS_MAX_STATS=100
METRICS_ENABLE_TRACING=false
METRICS_ENABLE_SQL_ANALYSIS=false
METRICS_ENABLE_SYSTEM_MONITOR=false

# ===================
# 文件上传配置
# ===================
UPLOAD_DIR=./uploads

# ===================
# 静态资源配置
# ===================
STATIC_PREFIX=/static
STATIC_ROOT=./static

# ===================
# 媒体资源配置
# ===================
MEDIA_PREFIX=/media
MEDIA_CACHE_ROOT=./media_cache
MEDIA_CACHE_DISABLED=false

# ===================
# 存储配置（pkg/stores：录音 files / 静态上传）
# ===================
# 后端: local | cos | minio | qiniu | oss | s3（默认 local）
STORAGE_KIND=local
# 可选：写入时传入的 bucket（云厂商多维一体时已各有 *_BUCKET / COS_BUCKET_NAME 等时可为空）
STORAGE_BUCKET=
# 本地盘上传对外访问 URL 前缀（录音入库 recording_url 用；例如 https://your-api.example.com/media）
STORAGE_PUBLIC_BASE_URL=http://localhost:7072/media

# 腾讯云 COS（STORAGE_KIND=cos）：COS_SECRET_ID, COS_SECRET_KEY, COS_REGION, COS_BUCKET_NAME

# 灵枢存储配置（当 STORAGE_KIND=qiniu 时使用）
# QINIU_ACCESS_KEY=your-qiniu-access-key
# QINIU_SECRET_KEY=your-qiniu-secret-key
# QINIU_BUCKET=your-bucket-name
# QINIU_DOMAIN=your-domain.com
# QINIU_REGION=z0
# QINIU_PRIVATE=false

# 腾讯云COS存储配置（当 STORAGE_KIND=cos 时使用）
# SECRET_ID=your-secret-id
# SECRET_KEY=your-secret-key
# REGION=ap-beijing
# BUCKET_NAME=your-bucket-name

# MinIO存储配置（当 STORAGE_KIND=minio 时使用）
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=your-minio-access-key
# MINIO_SECRET_KEY=your-minio-secret-key
# MINIO_BUCKET=your-bucket-name
# MINIO_USE_SSL=false
# MINIO_PUBLIC_BASE=https://your-domain.com

# S3 / 兼容 S3（STORAGE_KIND=s3）：S3_REGION, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_BUCKET, S3_ENDPOINT（可选）, S3_DOMAIN（公开访问域名）

# ACD 坐席排班（acd_pool_targets.shift_schedule_json）：清理任务会将「非 busy」且当前不在班次内的坐席标为 offline（IANA 时区）
# ACD_SHIFT_TIMEZONE=Asia/Shanghai

# SIP 转人工：单坐席振铃超时(ms) 后取消 INVITE 并尝试下一个空闲目标（数据库 acd_pool_targets 路由）
# SIP_TRANSFER_ANSWER_TIMEOUT_MS=30000

# Web 坐席：浏览器未在时限内 join 则释放并让系统尝试下一个 ACD 目标（默认 30s）
# SIP_WEBSEAT_JOIN_TIMEOUT=30s

# 本地缓存配置（当 CACHE_TYPE=local 或 gocache 时使用）
# LOCAL_CACHE_MAX_SIZE=1000
# LOCAL_CACHE_DEFAULT_EXPIRATION=5m
# LOCAL_CACHE_CLEANUP_INTERVAL=10m

# ===================
# SSL/TLS 配置
# ===================
# 启用SSL/TLS（设置为true启用HTTPS）
SSL_ENABLED=false

# SSL证书文件路径（启用SSL时必填）
# 证书文件路径（通常为 .crt 或 .pem 文件）
SSL_CERT_FILE=./ssl/lingecho.com_bundle.pem

# SSL私钥文件路径（启用SSL时必填）
# 私钥文件路径（通常为 .key 文件）
SSL_KEY_FILE=./ssl/lingecho.com.key

# 声纹识别服务配置示例
# 复制此文件为 .env 并根据实际情况修改配置

# 缓存配置
CACHE_TYPE=local
# 如果使用 Redis 缓存
# CACHE_TYPE=redis
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===================
# 外呼网关（统一从数据库读取）
# ===================
# 现状：
#   1. 在「中继线路」（Trunk）里配置 LocalAddr=host:port —— 同时提供给「转呼」与「外呼」。
#   2. 在「中继号码」（TrunkNumber）里把号码的 direction 设成 outbound / both —— 启用外呼。
#   3. 主叫身份 (number / display name) 来自 TrunkNumber.Number / TrunkNumber.CallerDisplayName。
#
# 注：外呼不再读取 SIP_OUTBOUND_*、SIP_SIGNALING_ADDR、SIP_TARGET_NUMBER（已移除）。
#     SIP_TRANSFER_* 仍可用于未接数据库的独立二进制里的转人工试拨；正常部署以中继 + ACD 为准。
#     SIP_CALLER_ID / SIP_CALLER_DISPLAY_NAME 在无中继主叫配置时仍可作 From 兜底。